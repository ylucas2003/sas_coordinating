# Copie para .env e preencha. O .env não vai para o git (ver .gitignore).

# Supabase — credenciais do projeto.
# As duas chaves vêm de https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_ANON_KEY=<chave-publica-jwt>
SUPABASE_SERVICE_KEY=<chave-de-servico-jwt>   # usada só pelo backend, NUNCA expor no frontend

# Postgres do Supabase — usado pelo migration runner (scripts/migrate.py).
# Pegue em https://supabase.com/dashboard/project/<id>/settings/database
# Recomendado: "Connection string" do pooler em "Transaction mode" (porta 6543).
# Formato: postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres

# Storage — Supabase Storage por default (S3-compatível).
# Se quiser usar AWS S3 mesmo, descomente e ajuste.
STORAGE_BUCKET=sas-uploads
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# CORS — origens permitidas (frontend em dev e em produção).
CORS_ALLOW_ORIGINS=http://localhost:5173,https://sas.vercel.app

# App.
APP_ENV=dev
