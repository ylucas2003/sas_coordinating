# Copie para .env e preencha. O .env não vai para o git (ver .gitignore).

# Credenciais AWS — use UMA das duas formas abaixo, não as duas.
#
# Forma 1 (recomendada): um profile já configurado em ~/.aws/credentials
# (via `aws configure`). Só precisa dizer qual profile usar:
# AWS_PROFILE=sas
#
# Forma 2: chaves cruas direto no ambiente (evite deixar isso num .env
# de verdade por muito tempo — prefira a Forma 1 sempre que der).
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...          # só se a credencial for temporária/SSO

# Conta/região AWS de destino do deploy. Normalmente NÃO precisa preencher —
# o CDK já infere isso sozinho a partir do profile/credenciais acima. Só
# defina se quiser forçar uma conta/região diferente da default do profile.
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=us-east-1

# URL pública do backend do SAS (FastAPI) — obrigatória. Ainda não existe
# porque a decisão de hosting (Render/Fly/Railway) está em aberto
# (ver docs/06-open-questions.md).
SAS_API_BASE_URL=https://sas-api.example.com

# Segredo compartilhado com o FastAPI (header X-Scheduler-Secret) —
# obrigatório no deploy. O valor canônico mora no SSM SecureString
# /sas/scheduler/secret; NÃO cole ele aqui — exporte na hora do deploy:
#   export SAS_SCHEDULER_SECRET=$(aws ssm get-parameter --name /sas/scheduler/secret \
#     --with-decryption --query Parameter.Value --output text)

# Silencia o aviso do CDK sobre a versão do Node instalada nesta máquina
# (v26, mais nova que as oficialmente testadas) não ser suportada oficialmente.
JSII_SILENCE_WARNING_UNTESTED_NODE_VERSION=1
